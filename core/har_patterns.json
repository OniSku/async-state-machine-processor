{
  "_comment": "HAR Patterns - Portfolio Version",
  "_description": "URL and payload patterns for HTTP request replay",
  "session_based": [],
  "tender_based": [],
  "lot_based": [],
  "patterns": {
    "url_patterns": {
      "_template": "{portal_url}/ru/.../{placeholder}"
    },
    "payload_patterns": {
      "_template": "Dynamic payload with placeholders"
    },
    "annex_11": {
      "url_pattern": "{portal_url}/ru/application/copy_data_docs/{announce_id}/{lot_id}//3335",
      "payload_patterns": {
        "search": {
          "_comment": "Fields marked with {placeholder} are dynamically filled"
        },
        "apply": {
          "_comment": "Fields marked with {placeholder} are dynamically filled"
        }
      },
      "dynamic_fields": [
        "anno_number",
        "from_lot",
        "to_lot[]"
      ],
      "static_fields": {
        "search": "Найти",
        "submit": "Применить"
      }
    },
    "annex_4": {
      "save_url_pattern": "{portal_url}/ru/beneficiary/ajax_save_info",
      "payload_pattern": {
        "_comment": "Beneficiary data with placeholders"
      },
      "dynamic_fields": [
        "beneficiary_doc_number",
        "app_lot_id",
        "userfile[1][]"
      ]
    },
    "annex_19": {
      "url_pattern": "{portal_url}/ru/application/show_doc/{announce_id}/{app_id}//3328/{announce_id}/1/?show=3",
      "payload_pattern": {
        "_comment": "Electronic data form with placeholders"
      },
      "dynamic_fields": [],
      "static_fields": {
        "save_electronic_data": "Сохранить"
      }
    }
  },
  "id_classification": {
    "_comment": "ID classification for HTML parsing",
    "app_ids": {
      "type": "session_based",
      "description": "Application IDs change per session"
    },
    "announce_ids": {
      "type": "tender_based",
      "description": "Announce IDs are static per tender"
    },
    "lot_ids": {
      "type": "lot_based",
      "description": "Lot IDs change per lot within tender"
    },
    "doc_ids": {
      "type": "tender_based",
      "description": "Document type IDs are static"
    },
    "file_ids": {
      "type": "session_based",
      "description": "File IDs change per session"
    }
  }
}