{
  "_comment": "HAR Config - Portfolio Version (Template)",
  "_description": "This file contains captured HTTP patterns for replaying requests",
  "annex_11": {
    "copy_data_docs": {
      "url_pattern": "{portal_url}/ru/application/copy_data_docs/{announce_id}/{lot_id}//3335",
      "search_payload": {
        "from_lot": "{source_lot_id}",
        "to_lot[]": "{target_lot_id}",
        "anno_number": "{source_announce_id}",
        "submit": "Применить"
      },
      "dynamic_fields": [
        "anno_number",
        "from_lot",
        "to_lot[]"
      ],
      "static_fields": {
        "search": "Найти",
        "submit": "Применить"
      }
    }
  },
  "annex_4": {
    "ajax_save_info": {
      "url_pattern": "{portal_url}/ru/beneficiary/ajax_save_info",
      "payload": {
        "beneficiary_name": "{beneficiary_name}",
        "citizenship": "{citizenship_code}",
        "res_country": "{country_code}",
        "beneficiary_doc_number": "{doc_number}",
        "beneficiary_doc_date": "{doc_date}",
        "option_1": "0",
        "option_2": "0",
        "option_3": "0",
        "option_4": "1",
        "app_lot_id": "{app_lot_id}",
        "userfile[1][]": "{userfile[1][]}"
      },
      "dynamic_fields": [
        "beneficiary_doc_number",
        "app_lot_id",
        "userfile[1][]"
      ]
    }
  },
  "annex_19": {
    "electronic_data": {
      "url_pattern": "{portal_url}/ru/application/show_doc/{announce_id}/{app_id}//3328/{announce_id}/1/?show=3",
      "payload": {
        "typeDoc": "{doc_type_id}",
        "save_electronic_data": "Сохранить"
      },
      "show_params": {
        "show": "3"
      },
      "dynamic_fields": [],
      "static_fields": {
        "save_electronic_data": "Сохранить"
      }
    }
  },
  "id_classification": {
    "_comment": "ID types for auto-detection in HTML",
    "app_ids": {
      "type": "session_based",
      "description": "Application IDs change per session"
    },
    "announce_ids": {
      "type": "tender_based",
      "description": "Announce IDs are static per tender"
    },
    "lot_ids": {
      "type": "lot_based",
      "description": "Lot IDs change per lot within tender"
    },
    "doc_ids": {
      "type": "tender_based",
      "description": "Document type IDs are static"
    },
    "file_ids": {
      "type": "session_based",
      "description": "File IDs change per session"
    }
  }
}